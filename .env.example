# ---------------------------------------------------------------------------
# arc-agent-starter — environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values you need:
#
#     cp .env.example .env.local
#
# RULES:
#   * .env.local is gitignored. NEVER commit it.
#   * This template ships with EVERY value empty on purpose — so there are no
#     secrets, and no fake-looking addresses, in version control.
#   * Sensible PUBLIC defaults (testnet registry/asset addresses, demo builder
#     code, the public Arc RPC) live in the source code, not here, so the app
#     runs out of the box even with this file untouched. You only set a value
#     here when you want to override a default with your own.
#   * Anything prefixed NEXT_PUBLIC_ is exposed to the browser bundle. Never put
#     a secret behind a NEXT_PUBLIC_ name.
# ---------------------------------------------------------------------------

# --- Arc chain (Primitive: all) -------------------------------------------
# Override the default public Arc testnet RPC if you run your own node.
NEXT_PUBLIC_ARC_RPC_URL=

# --- x402 client-side payments (Primitive 2) ------------------------------
# The address that should RECEIVE the micropayment for the gated endpoint
# (typically your own wallet). Falls back to a demo address in code if empty.
X402_PAY_TO=
# The USDC token contract used in the EIP-3009 payment authorization domain.
# Falls back to a demo placeholder in code if empty.
X402_ASSET=

# --- Builder-code order attribution (Primitive 3) -------------------------
# Your builder code as a bytes32 hex string. SERVER-ONLY — note there is NO
# NEXT_PUBLIC_ prefix, so it never ends up in the browser bundle. The relay
# route serves it to the client at request time and verifies it on submit.
# Falls back to a demo code (keccak of a label) in code if empty.
POLY_BUILDER_CODE=
# The downstream order book / venue URL the relay forwards signed orders to.
# Leave empty to run the relay in local "demo echo" mode (no external call).
ORDER_RELAY_URL=

# --- Attestation oracle (Primitive 5) -------------------------------------
# Address of YOUR deployed AttestationOracle (see contracts/ + docs/01).
# The oracle demo page reads from this. Empty = the page shows deploy steps.
NEXT_PUBLIC_ORACLE_ADDRESS=

# --- Foundry deploy (contracts/) ------------------------------------------
# Private key used ONLY by `forge script` to broadcast a deployment.
# Use a throwaway testnet key. Never reuse a key that holds real funds.
PRIVATE_KEY=
